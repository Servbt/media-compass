# Media Compass API
PORT=3001
HOST=127.0.0.1
FRONTEND_ORIGIN=http://localhost:5173
# Optional. If set, non-GET API requests require Authorization: Bearer <API_TOKEN>.
API_TOKEN=
MEDIA_COMPASS_DATA_FILE=.data/media-compass.json

# Required only when running `npm run migrate:server` against Postgres/Supabase.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/media_compass

# Frontend opt-in for API-backed mode. Leave blank to use localStorage fallback.
VITE_API_BASE_URL=http://localhost:3001
# Only needed if API_TOKEN is set; local/dev convenience, not serious auth.
VITE_API_TOKEN=
